{
    "name": "krsque/php-ext-protobuf-stubs",
    "description": "PHPStan / Psalm / PhpStorm stubs for ext-protobuf (the protobuf C extension for PHP)",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "protobuf",
        "stubs",
        "phpstan",
        "psalm",
        "static-analysis",
        "ide"
    ],
    "require": {
        "php": ">=8.2"
    },
    "conflict": {
        "ext-protobuf": "!=5.35.1"
    },
    "extra": {
        "phpstan": {
            "includes": [
                "extension.neon"
            ]
        }
    }
}
